# ============================================================
# Supabase environment variables
#
# How to get these values:
#   1. Go to https://supabase.com and open your project
#   2. Settings → API
#   3. Copy "Project URL" and the keys below
#
# Next.js web (menu público):
#   Copy this file to: web/.env.local
#
# Expo app (dueño):
#   Copy this file to: app/.env
#   Note: Expo uses EXPO_PUBLIC_ prefix for client-side vars
# ============================================================

# ---- Supabase project URL ----
# Found in: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# ---- Anon / public key ----
# Safe to expose in client-side code — RLS protects the data
# Found in: Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Service role key ----
# NEVER expose this in client code or commit it to git
# Only used in server-side Next.js (API routes / Server Actions)
# Found in: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
