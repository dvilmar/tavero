# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para docker-compose.prod.yml en el VPS
# Copia este archivo como `.env` en /opt/tavero/ del servidor
# ─────────────────────────────────────────────────────────────────────────────

# Imagen Docker a desplegar (GitHub Actions la sobreescribe automáticamente)
TAVERO_IMAGE=ghcr.io/TU-GITHUB-USER/tavero-web:latest

# Supabase — valores públicos (aparecen en el bundle JS del cliente)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — clave de servidor (NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
